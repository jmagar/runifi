{
  "name": "unifi-rmcp",
  "version": "0.2.4",
  "description": "Node launcher for the UniFi Rust MCP server and runifi CLI for network controller operations.",
  "license": "MIT",
  "homepage": "https://github.com/jmagar/unifi-rmcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jmagar/unifi-rmcp.git",
    "directory": "packages/unifi-rmcp"
  },
  "bugs": {
    "url": "https://github.com/jmagar/unifi-rmcp/issues"
  },
  "bin": {
    "unifi-rmcp": "bin/runifi.js",
    "runifi": "bin/runifi.js"
  },
  "files": [
    "bin/",
    "lib/",
    "scripts/",
    "README.md"
  ],
  "scripts": {
    "postinstall": "node scripts/install.js",
    "test": "node --test",
    "check": "node --check bin/runifi.js && node --check scripts/install.js && node --check lib/platform.js"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "rmcp",
    "rust",
    "unifi",
    "ubiquiti",
    "networking",
    "wifi",
    "network-controller",
    "homelab",
    "cli",
    "claude-code",
    "codex",
    "gemini",
    "automation",
    "oauth",
    "http-server"
  ]
}
